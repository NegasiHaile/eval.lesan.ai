# Copy this file to .env or .env.local and fill in your values.
# Do not commit .env or .env.local (they are gitignored).

# App Info
APP_NAME=HornEval
NEXT_PUBLIC_APP_NAME=HornEval
APP_VERSION=1.0.0
APP_DESCRIPTION=Machine Translations Human Evaluation & Leaderboard

# MongoDB Configuration
MONGODB_DB=production
MONGODB_URI=mongodb://localhost:27017/

# API Configuration
LESAN_API_URL=https://api.lesan.ai/translate/v1
LESAN_API_KEY=your_lesan_api_key
GEMINI_API_KEY=your_gemini_api_key

# SMTP (e.g. Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=HornEval
SMTP_SERVICE=gmail
SMTP_SECURE=false

# Optional: SendGrid (alternative to SMTP)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_SENDER_EMAIL=your-verified-sender@example.com

# Token expiration (milliseconds)
FORGET_PASSWORD_TOKEN_EXPIRATION=1800000
CONFIRM_EMAIL_TOKEN_EXPIRATION=473040000000

# URLs
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
ROOT_URI=http://localhost:3000

# Optional: Google Cloud (e.g. for GCS storage)
GCP_PROJECT_ID=your-project-id
GCP_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GCS_BUCKET=your-bucket-name
