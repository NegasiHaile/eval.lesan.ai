# Copy this file to .env or .env.local and fill in your values.
# Do not commit .env or .env.local (they are gitignored).

# Better Auth (required for sign-in and protected API routes)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-auth-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# Email (Nodemailer) – required for email verification and forgot password
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@example.com

# Social sign-in (add any you use; at least one required for auth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
HUGGINGFACE_CLIENT_ID=your-huggingface-client-id
HUGGINGFACE_CLIENT_SECRET=your-huggingface-client-secret

# App Info
APP_NAME=HornEval
NEXT_PUBLIC_APP_NAME=HornEval
APP_VERSION=1.0.0
APP_DESCRIPTION=Machine Translations Human Evaluation & Leaderboard
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# MongoDB (database name defaults to NODE_ENV: "development" or "production")
MONGODB_URI=mongodb+srv://user:pass@cluster.xxx.mongodb.net/

# API Configuration
LESAN_API_URL=https://api.lesan.ai/translate/v1
LESAN_API_KEY=your_lesan_api_key
GEMINI_API_KEY=your_gemini_api_key
